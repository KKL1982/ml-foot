@{
    ViewData["Title"] = "Dashboard";
    string modelMode = ViewData["ModelMode"] as string ?? "Binary";
}

<div class="page-title">Dashboard</div>
<div class="page-subtitle">Football prediction system — Binary mode (Home/Away) &middot; 71.4% accuracy</div>

<div class="kpi-grid">
    <div class="kpi-card kpi-blue">
        <div class="kpi-header">📊 Dataset</div>
        <div class="kpi-value">14 211</div>
        <div class="kpi-sub">Matches — Premier League, LaLiga, Bundesliga, Ligue 1</div>
    </div>
    <div class="kpi-card kpi-purple">
        <div class="kpi-header">🧠 Models</div>
        <div class="kpi-value">8</div>
        <div class="kpi-sub">4 multiclass + 4 binary classifiers</div>
    </div>
    <div class="kpi-card kpi-green">
        <div class="kpi-header">🎯 Active Model</div>
        <div class="kpi-value" style="font-size:22px">@(modelMode == "Binary" ? "Binary" : "Multiclass")</div>
        <div class="kpi-sub">
            @if (modelMode == "Binary")
            {
                <span>LbfgsLogisticRegression &middot; Accuracy <strong>71.4%</strong> &middot; F1 0.78 &middot; AUC 0.78</span>
            }
            else
            {
                <span>LbfgsMaximumEntropy &middot; Accuracy <strong>53.0%</strong> (experimental)</span>
            }
        </div>
        @if (modelMode == "Binary")
        {
            <div class="kpi-delta" style="color:var(--green)">↑ +18 pts vs multiclass (53%)</div>
        }
    </div>
    <div class="kpi-card kpi-yellow">
        <div class="kpi-header">⚽ Leagues</div>
        <div class="kpi-value">4</div>
        <div class="kpi-sub">Premier League · LaLiga · Bundesliga · Ligue 1</div>
    </div>
    <div class="kpi-card kpi-blue">
        <div class="kpi-header">👥 Coach Coverage</div>
        <div class="kpi-value">100%</div>
        <div class="kpi-sub">300+ coach intervals mapped · 132 teams</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-header">⏱️ Training Period</div>
        <div class="kpi-value" style="font-size:22px">10 seasons</div>
        <div class="kpi-sub">2015–2016 → 2024–2025</div>
    </div>
</div>

<div class="alert alert-warning">
    ⚠️ This tool is experimental. Predictions do not constitute financial advice.
    @if (modelMode == "Binary")
    {
        <span>Draws are excluded — only Home/Away predictions with confidence threshold.</span>
    }
</div>

<div class="row-2">
    <div class="card">
        <div class="card-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            Model Comparison (Multiclass — Experimental)
        </div>
        <div class="chart-wrap chart-wrap-md">
            <canvas id="chartMulticlass"></canvas>
        </div>
        <div style="margin-top:16px;font-size:12px;color:var(--tx3)">
            All models struggle with draws (>95% misclassified). Best: Lbfgs 52.97%.
        </div>
    </div>
    <div class="card">
        <div class="card-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            Model Comparison (Binary — Active)
        </div>
        <div class="chart-wrap chart-wrap-md">
            <canvas id="chartBinary"></canvas>
        </div>
        <div style="margin-top:16px;font-size:12px;color:var(--tx3)">
            Removing draws boosts accuracy from 53% to 71%. Best: LbfgsLogisticRegression.
        </div>
    </div>
</div>

<div class="feature-grid">
    <div class="feature-card">
        <div class="feature-icon" style="background:rgba(56,189,248,.15)">🔮</div>
        <h4>Binary Prediction</h4>
        <p>Home/Away with confidence threshold. Skip uncertain matches. F1 0.78, AUC 0.78.</p>
        <a href="/prediction" class="btn btn-blue btn-sm" style="margin-top:12px">New Prediction →</a>
    </div>
    <div class="feature-card">
        <div class="feature-icon" style="background:rgba(34,197,94,.15)">📁</div>
        <h4>Batch CSV Processing</h4>
        <p>Upload a CSV file with multiple matches and get binary predictions for all of them.</p>
        <a href="/batch" class="btn btn-green btn-sm" style="margin-top:12px">Upload CSV →</a>
    </div>
    <div class="feature-card">
        <div class="feature-icon" style="background:rgba(167,139,250,.15)">🧠</div>
        <h4>Neural Network</h4>
        <p>Custom MLP with embeddings (21K params). Adam optimizer, He initialization, from-scratch C#.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon" style="background:rgba(250,204,21,.15)">📈</div>
        <h4>API Access</h4>
        <p>REST endpoints at <code>/api/predict</code> and <code>/api/health</code>. JSON in, JSON out.</p>
        <a href="/api/health" class="btn btn-outline btn-sm" style="margin-top:12px">Health Check →</a>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
new Chart(document.getElementById('chartMulticlass'), {
    type: 'bar',
    data: {
        labels: ['Sdca', 'Lbfgs', 'LightGbm', 'NeuralNet'],
        datasets: [{
            label: 'Accuracy %',
            data: [49.7, 52.97, 51.78, 49.38],
            backgroundColor: ['#64748b', '#38bdf8', '#22c55e', '#a78bfa'],
            borderRadius: 8
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { min: 45, max: 55, grid: { color: '#1e2d47' }, ticks: { color: '#94a3b8', callback: v => v + '%' } },
            x: { ticks: { color: '#94a3b8' } }
        }
    }
});

new Chart(document.getElementById('chartBinary'), {
    type: 'bar',
    data: {
        labels: ['SdcaBin', 'LbfgsBin', 'LightGbmBin', 'NeuralNetBin'],
        datasets: [{
            label: 'Accuracy %',
            data: [71.12, 71.40, 69.95, 69.43],
            backgroundColor: ['#64748b', '#38bdf8', '#22c55e', '#a78bfa'],
            borderRadius: 8
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { min: 65, max: 75, grid: { color: '#1e2d47' }, ticks: { color: '#94a3b8', callback: v => v + '%' } },
            x: { ticks: { color: '#94a3b8' } }
        }
    }
});
</script>
}
