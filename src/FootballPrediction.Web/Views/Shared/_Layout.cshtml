<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Football AI</title>
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>

    <!-- Loading Spinner -->
    <div class="spinner-overlay" id="spinner"><div class="spinner"></div></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polygon points="12,6 9,10 15,10"/><line x1="12" y1="14" x2="12" y2="18"/>
            </svg>
            Football AI
        </div>
        <nav class="sidebar-nav">
            @{ string? cur = ViewContext.RouteData.Values["controller"]?.ToString(); }
            <a href="/" class="@(cur == "Home" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Dashboard
            </a>
            <a href="/prediction" class="@(cur == "Prediction" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Predict
            </a>
            <a href="/batch" class="@(cur == "Batch" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                CSV Upload
            </a>
        </nav>
        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span style="font-size:11px;color:var(--tx3);display:block;margin-bottom:6px">👤 @User.Identity.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                    <button type="submit" class="btn btn-outline btn-sm" style="width:100%;font-size:11px">🚪 Sign Out</button>
                </form>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-outline btn-sm" style="width:100%">🔑 Sign In</a>
            }
            <div style="margin-top:8px">&copy; @DateTime.Now.Year Football AI</div>
        </div>
    </aside>

    <!-- Header -->
    <header class="header">
        <button class="header-menu" onclick="document.getElementById('sidebar').classList.toggle('open')">&#9776;</button>
        <div class="header-title">@ViewData["Title"]</div>
        <div class="header-meta">
            <span>&#128197; @DateTime.Now.ToString("dd MMM yyyy")</span>
            <span>&#129504; Model active</span>
        </div>
        <a href="/batch" class="btn btn-blue btn-sm">&#128193; Import CSV</a>
        <a href="/prediction" class="btn btn-green btn-sm">&#9917; New Prediction</a>
    </header>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Upload zone drag & drop (only on batch page) -->
    <script>
        (function() {
            var zone = document.getElementById('uploadZone');
            var file = document.getElementById('fileInput');
            if (!zone || !file) return;
            zone.addEventListener('click', function() { file.click(); });
            zone.addEventListener('dragover',  function(e) { e.preventDefault(); zone.classList.add('drag'); });
            zone.addEventListener('dragleave', function() { zone.classList.remove('drag'); });
            zone.addEventListener('drop', function(e) {
                e.preventDefault(); zone.classList.remove('drag');
                file.files = e.dataTransfer.files;
                var txt = zone.querySelector('.upload-text');
                if (txt && file.files[0]) txt.innerHTML = '&#128196; <strong>' + file.files[0].name + '</strong>';
            });
            file.addEventListener('change', function() {
                var txt = zone.querySelector('.upload-text');
                if (txt && file.files[0]) txt.innerHTML = '&#128196; <strong>' + file.files[0].name + '</strong>';
            });
            // Show spinner on form submit
            var form = zone.closest('form');
            if (form) form.addEventListener('submit', function() {
                document.getElementById('spinner').classList.add('active');
            });
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
