@model FootballPrediction.Web.Models.PredictionInputViewModel
@{
    ViewData["Title"] = "Binary Prediction";
}

<div class="page-title">Predict a Match</div>
<div class="page-subtitle">Binary mode (Home/Away) — 71.4% accuracy &middot; <a href="#" onclick="toggleMode()" style="color:var(--yellow);text-decoration:underline">Switch to experimental 1X2</a></div>

<form asp-action="Predict" method="post" onsubmit="document.getElementById('spinner').classList.add('active')">
    <input type="hidden" asp-for="Mode" id="modeInput" />

    <div class="card">
        <div class="card-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="12,6 9,10 15,10"/><line x1="12" y1="14" x2="12" y2="18"/></svg>
            Match Information
        </div>
        <div asp-validation-summary="All" style="color:var(--red);font-size:12px;margin-bottom:16px"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Date" class="form-label">📅 Match Date</label>
                <input asp-for="Date" type="date" class="form-control" />
                <span asp-validation-for="Date" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="League" class="form-label">🏆 League</label>
                <select asp-for="League" class="form-select" id="LeagueSelect">
                    <option value="">-- Select League --</option>
                    <option>Premier League</option>
                    <option>LaLiga</option>
                    <option>Bundesliga</option>
                    <option>Ligue 1</option>
                    <option>Serie A</option>
                </select>
                <span asp-validation-for="League" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="HomeTeam" class="form-label">🏠 Home Team</label>
                <input asp-for="HomeTeam" class="form-control" id="HomeTeamInput" placeholder="e.g. Arsenal" />
                <span asp-validation-for="HomeTeam" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="AwayTeam" class="form-label">✈️ Away Team</label>
                <input asp-for="AwayTeam" class="form-control" id="AwayTeamInput" placeholder="e.g. Chelsea" />
                <span asp-validation-for="AwayTeam" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="HomeCoach" class="form-label">👔 Home Coach</label>
                <input asp-for="HomeCoach" class="form-control" placeholder="Optional — improves accuracy" />
            </div>
            <div class="form-group">
                <label asp-for="AwayCoach" class="form-label">👔 Away Coach</label>
                <input asp-for="AwayCoach" class="form-control" placeholder="Optional — improves accuracy" />
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            Bookmaker Odds
            <button type="button" class="btn btn-blue btn-sm" style="margin-left:auto" onclick="fetchLiveOdds()" id="fetchBtn">
                🔄 Fetch Live Odds
            </button>
        </div>
        <div id="fetchStatus" style="display:none;margin-bottom:12px;padding:8px 12px;border-radius:8px;font-size:12px"></div>
        <div class="form-grid-3">
            <div class="odds-box">
                <div class="odds-box-title"><span class="dot dot-bet365"></span> Bet365</div>
                <div class="odds-row">
                    <span class="odds-row-label home">1</span>
                    <input asp-for="Bet365Home" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 2.10" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label draw">X</span>
                    <input asp-for="Bet365Draw" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 3.50" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label away">2</span>
                    <input asp-for="Bet365Away" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 4.00" />
                </div>
            </div>
            <div class="odds-box">
                <div class="odds-box-title"><span class="dot dot-pinnacle"></span> Pinnacle</div>
                <div class="odds-row">
                    <span class="odds-row-label home">1</span>
                    <input asp-for="PinnacleHome" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 2.15" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label draw">X</span>
                    <input asp-for="PinnacleDraw" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 3.40" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label away">2</span>
                    <input asp-for="PinnacleAway" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 3.90" />
                </div>
            </div>
            <div class="odds-box">
                <div class="odds-box-title"><span class="dot" style="background:var(--yellow)"></span> William Hill</div>
                <div class="odds-row">
                    <span class="odds-row-label home">1</span>
                    <input asp-for="WilliamHillHome" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 2.05" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label draw">X</span>
                    <input asp-for="WilliamHillDraw" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 3.55" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label away">2</span>
                    <input asp-for="WilliamHillAway" type="number" step="0.01" class="form-control odds-input" placeholder="e.g. 4.10" />
                </div>
            </div>
        </div>

        <div style="margin-top:20px;display:flex;align-items:center;gap:12px">
            <label asp-for="BinaryThreshold" style="font-size:13px;color:var(--tx2);white-space:nowrap">🎯 Confidence threshold:</label>
            <input asp-for="BinaryThreshold" type="range" min="0.5" max="0.95" step="0.05" class="form-range" style="flex:1"
                   oninput="this.nextElementSibling.textContent = (this.value*100).toFixed(0) + '%'" />
            <span style="font-size:13px;font-weight:700;color:var(--green);min-width:40px">50%</span>
        </div>

        <button type="submit" class="btn btn-green btn-lg" style="width:100%;margin-top:20px">
            ⚡ Predict (Binary)
        </button>
    </div>
</form>

<script>
function toggleMode() {
    var input = document.getElementById('modeInput');
    var title = document.querySelector('.page-title');
    var subtitle = document.querySelector('.page-subtitle');
    if (input.value === 'Multiclass') {
        input.value = 'Binary';
        title.textContent = 'Predict a Match';
        subtitle.innerHTML = 'Binary mode (Home/Away) — 71.4% accuracy &middot; <a href="#" onclick="toggleMode()" style="color:var(--yellow);text-decoration:underline">Switch to experimental 1X2</a>';
        document.querySelector('.btn-green').textContent = '⚡ Predict (Binary)';
    } else {
        input.value = 'Multiclass';
        title.textContent = 'Predict a Match (1X2 Experimental)';
        subtitle.innerHTML = '⚠️ Experimental multiclass mode — 53% accuracy &middot; <a href="#" onclick="toggleMode()" style="color:var(--green);text-decoration:underline">Switch to Binary</a>';
        document.querySelector('.btn-green').textContent = '⚡ Predict (1X2)';
    }
}

// ── Fetch Live Odds ──
async function fetchLiveOdds() {
    var league = document.getElementById('LeagueSelect').value;
    var homeTeam = document.getElementById('HomeTeamInput').value.trim();
    var awayTeam = document.getElementById('AwayTeamInput').value.trim();
    var btn = document.getElementById('fetchBtn');
    var status = document.getElementById('fetchStatus');

    if (!league || !homeTeam || !awayTeam) {
        showStatus('⚠️ Please select a league and enter both team names first.', 'warning');
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '⏳ Fetching...';
    status.style.display = 'block';
    status.style.background = 'rgba(92,200,255,.1)';
    status.style.color = 'var(--blue)';
    status.textContent = 'Fetching live odds...';

    try {
        var url = '/Odds/fetch?league=' + encodeURIComponent(league) +
                  '&homeTeam=' + encodeURIComponent(homeTeam) +
                  '&awayTeam=' + encodeURIComponent(awayTeam);

        var resp = await fetch(url);

        // Attempt to parse JSON regardless of status code
        var data;
        try {
            var text = await resp.text();
            if (!text || text.trim().length === 0) {
                throw new Error('Server returned empty response. Check if the container is running.');
            }
            data = JSON.parse(text);
        } catch (jsonErr) {
            // Response is not JSON (HTML error page, redirect, etc.)
            if (resp.status === 302 || resp.status === 401 || resp.status === 403) {
                throw new Error('Session expired. Please refresh and log in again.');
            }
            if (resp.status >= 500) {
                throw new Error('Server error (HTTP ' + resp.status + '). Check Docker logs.');
            }
            throw new Error('Unexpected response from server (HTTP ' + resp.status + '). Try again later.');
        }

        if (data.error) {
            showStatus('⚠️ ' + data.error, 'warning');
            btn.disabled = false;
            btn.innerHTML = '🔄 Fetch Live Odds';
            return;
        }

        // Fill Bet365 odds
        if (data.bet365Home) document.querySelector('[name="Bet365Home"]').value = data.bet365Home;
        if (data.bet365Draw) document.querySelector('[name="Bet365Draw"]').value = data.bet365Draw;
        if (data.bet365Away) document.querySelector('[name="Bet365Away"]').value = data.bet365Away;

        // Fill Pinnacle odds
        if (data.pinnacleHome) document.querySelector('[name="PinnacleHome"]').value = data.pinnacleHome;
        if (data.pinnacleDraw) document.querySelector('[name="PinnacleDraw"]').value = data.pinnacleDraw;
        if (data.pinnacleAway) document.querySelector('[name="PinnacleAway"]').value = data.pinnacleAway;

        showStatus('✅ Odds loaded from ' + data.league + ' — ' + data.matchDate, 'success');
    } catch (e) {
        showStatus('❌ ' + e.message, 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '🔄 Fetch Live Odds';
    }
}

function showStatus(msg, type) {
    var status = document.getElementById('fetchStatus');
    status.style.display = 'block';
    status.textContent = msg;
    if (type === 'success') {
        status.style.background = 'rgba(45,212,122,.12)';
        status.style.color = 'var(--green)';
    } else if (type === 'error') {
        status.style.background = 'rgba(255,107,107,.12)';
        status.style.color = 'var(--red)';
    } else {
        status.style.background = 'rgba(244,197,66,.12)';
        status.style.color = 'var(--yellow)';
    }
}
</script>
