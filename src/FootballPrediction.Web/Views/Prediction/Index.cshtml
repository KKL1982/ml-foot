@model FootballPrediction.Web.Models.PredictionInputViewModel
@{
    ViewData["Title"] = "Binary Prediction";
}

<div class="page-title">Predict a Match</div>
<div class="page-subtitle">Binary mode (Home/Away) — 71.4% accuracy &middot; <a href="#" onclick="toggleMode()" style="color:var(--yellow);text-decoration:underline">Switch to experimental 1X2</a></div>

<form asp-action="Predict" method="post" onsubmit="document.getElementById('spinner').classList.add('active')">
    <input type="hidden" asp-for="Mode" id="modeInput" />

    <div class="card">
        <div class="card-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="12,6 9,10 15,10"/><line x1="12" y1="14" x2="12" y2="18"/></svg>
            Match Information
        </div>
        <div asp-validation-summary="All" style="color:var(--red);font-size:12px;margin-bottom:16px"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="Date" class="form-label">📅 Match Date</label>
                <input asp-for="Date" type="date" class="form-control" />
                <span asp-validation-for="Date" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="League" class="form-label">🏆 League</label>
                <select asp-for="League" class="form-select">
                    <option value="">-- Select League --</option>
                    <option>Premier League</option>
                    <option>LaLiga</option>
                    <option>Bundesliga</option>
                    <option>Ligue 1</option>
                    <option>Serie A</option>
                </select>
                <span asp-validation-for="League" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="HomeTeam" class="form-label">🏠 Home Team</label>
                <input asp-for="HomeTeam" class="form-control" placeholder="e.g. Arsenal" />
                <span asp-validation-for="HomeTeam" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="AwayTeam" class="form-label">✈️ Away Team</label>
                <input asp-for="AwayTeam" class="form-control" placeholder="e.g. Chelsea" />
                <span asp-validation-for="AwayTeam" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="HomeCoach" class="form-label">👔 Home Coach</label>
                <input asp-for="HomeCoach" class="form-control" placeholder="Optional — improves accuracy" />
            </div>
            <div class="form-group">
                <label asp-for="AwayCoach" class="form-label">👔 Away Coach</label>
                <input asp-for="AwayCoach" class="form-control" placeholder="Optional — improves accuracy" />
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            Bookmaker Odds
        </div>
        <div class="form-grid-3">
            <div class="odds-box">
                <div class="odds-box-title"><span class="dot dot-bet365"></span> Bet365</div>
                <div class="odds-row">
                    <span class="odds-row-label home">1</span>
                    <input asp-for="Bet365Home" type="number" step="0.01" class="form-control" placeholder="e.g. 2.10" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label draw">X</span>
                    <input asp-for="Bet365Draw" type="number" step="0.01" class="form-control" placeholder="e.g. 3.50" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label away">2</span>
                    <input asp-for="Bet365Away" type="number" step="0.01" class="form-control" placeholder="e.g. 4.00" />
                </div>
            </div>
            <div class="odds-box">
                <div class="odds-box-title"><span class="dot dot-pinnacle"></span> Pinnacle</div>
                <div class="odds-row">
                    <span class="odds-row-label home">1</span>
                    <input asp-for="PinnacleHome" type="number" step="0.01" class="form-control" placeholder="e.g. 2.15" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label draw">X</span>
                    <input asp-for="PinnacleDraw" type="number" step="0.01" class="form-control" placeholder="e.g. 3.40" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label away">2</span>
                    <input asp-for="PinnacleAway" type="number" step="0.01" class="form-control" placeholder="e.g. 3.90" />
                </div>
            </div>
            <div class="odds-box">
                <div class="odds-box-title"><span class="dot" style="background:var(--yellow)"></span> William Hill</div>
                <div class="odds-row">
                    <span class="odds-row-label home">1</span>
                    <input asp-for="WilliamHillHome" type="number" step="0.01" class="form-control" placeholder="e.g. 2.05" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label draw">X</span>
                    <input asp-for="WilliamHillDraw" type="number" step="0.01" class="form-control" placeholder="e.g. 3.55" />
                </div>
                <div class="odds-row">
                    <span class="odds-row-label away">2</span>
                    <input asp-for="WilliamHillAway" type="number" step="0.01" class="form-control" placeholder="e.g. 4.10" />
                </div>
            </div>
        </div>

        <div style="margin-top:20px;display:flex;align-items:center;gap:12px">
            <label asp-for="BinaryThreshold" style="font-size:13px;color:var(--tx2);white-space:nowrap">🎯 Confidence threshold:</label>
            <input asp-for="BinaryThreshold" type="range" min="0.5" max="0.95" step="0.05" class="form-range" style="flex:1"
                   oninput="this.nextElementSibling.textContent = (this.value*100).toFixed(0) + '%'" />
            <span style="font-size:13px;font-weight:700;color:var(--green);min-width:40px">50%</span>
        </div>

        <button type="submit" class="btn btn-green btn-lg" style="width:100%;margin-top:20px">
            ⚡ Predict (Binary)
        </button>
    </div>
</form>

<script>
function toggleMode() {
    var input = document.getElementById('modeInput');
    var title = document.querySelector('.page-title');
    var subtitle = document.querySelector('.page-subtitle');
    if (input.value === 'Multiclass') {
        input.value = 'Binary';
        title.textContent = 'Predict a Match';
        subtitle.innerHTML = 'Binary mode (Home/Away) — 71.4% accuracy &middot; <a href="#" onclick="toggleMode()" style="color:var(--yellow);text-decoration:underline">Switch to experimental 1X2</a>';
        document.querySelector('.btn-green').textContent = '⚡ Predict (Binary)';
    } else {
        input.value = 'Multiclass';
        title.textContent = 'Predict a Match (1X2 Experimental)';
        subtitle.innerHTML = '⚠️ Experimental multiclass mode — 53% accuracy &middot; <a href="#" onclick="toggleMode()" style="color:var(--green);text-decoration:underline">Switch to Binary</a>';
        document.querySelector('.btn-green').textContent = '⚡ Predict (1X2)';
    }
}
</script>
