@model FootballPrediction.Web.Models.PredictionResultViewModel
@{
    ViewData["Title"] = "Prediction Result";
    string badgeClass = Model.PredictedResult switch { "1" => "badge-1", "X" => "badge-X", "2" => "badge-2", _ => "" };
    string verdict    = Model.PredictedResult switch { "1" => "Home Win", "X" => "Draw", "2" => "Away Win", _ => "" };
    string confClass  = Model.Confidence >= 0.6 ? "conf-high" : Model.Confidence >= 0.45 ? "conf-med" : "conf-low";
}

<div class="page-title">Prediction Result</div>

<div class="row-2">
    <div class="result-hero">
        <h3>@Model.HomeTeam vs @Model.AwayTeam</h3>
        <p class="sub">@Model.League &middot; @Model.Date.ToString("dd MMM yyyy")</p>
        <div class="result-badge">
            <span class="badge badge-xl @badgeClass">@Model.PredictedResult</span>
        </div>
        <div class="result-verdict">@verdict</div>
        <div class="result-comment">@Model.Comment</div>
        <span class="badge badge-lg @confClass">Confidence: @Model.Confidence.ToString("P0")</span>
        <div style="margin-top:14px;font-size:11px;color:var(--tx2)">@Model.ModelUsed</div>
    </div>

    <div class="card">
        <div class="card-header">&#128202; Probabilities</div>
        <div class="prob-group">
            <div class="prob-label">
                <span>&#127968; Home Win (1)</span>
                <strong style="color:var(--green)">@Model.Probability1.ToString("P1")</strong>
            </div>
            <div class="prob-bar"><div class="prob-fill prob-green" style="width:@(Model.Probability1*100)%"></div></div>
        </div>
        <div class="prob-group">
            <div class="prob-label">
                <span>&#129309; Draw (X)</span>
                <strong style="color:var(--yellow)">@Model.ProbabilityX.ToString("P1")</strong>
            </div>
            <div class="prob-bar"><div class="prob-fill prob-yellow" style="width:@(Model.ProbabilityX*100)%"></div></div>
        </div>
        <div class="prob-group" style="margin-bottom:0">
            <div class="prob-label">
                <span>&#9992; Away Win (2)</span>
                <strong style="color:var(--blue)">@Model.Probability2.ToString("P1")</strong>
            </div>
            <div class="prob-bar"><div class="prob-fill prob-blue" style="width:@(Model.Probability2*100)%"></div></div>
        </div>
    </div>
</div>

<div style="margin-top:24px">
    <a href="/prediction" class="btn btn-outline">&larr; New Prediction</a>
    <a href="/" class="btn btn-outline" style="margin-left:8px">&#127968; Dashboard</a>
</div>
