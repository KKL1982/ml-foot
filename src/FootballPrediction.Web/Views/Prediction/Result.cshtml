@model FootballPrediction.Web.Models.PredictionResultViewModel
@{
    ViewData["Title"] = "Prediction Result";
    string bc = Model.PredictedResult switch { "1" => "bg1", "X" => "bgx", "2" => "bg2", _ => "" };
    string txt = Model.PredictedResult switch { "1" => "Home Win", "X" => "Draw", "2" => "Away Win", _ => "" };
    string cc = Model.Confidence >= 0.6 ? "cf-hi" : Model.Confidence >= 0.45 ? "cf-md" : "cf-lo";
}

<div class="pg-title">Prediction Result</div>

<div class="row2x">
    <div class="res">
        <h3>@Model.HomeTeam vs @Model.AwayTeam</h3>
        <p class="sub">@Model.League &middot; @Model.Date.ToString("dd MMM yyyy")</p>
        <div class="res-badge"><span class="bg bg-xl @bc">@Model.PredictedResult</span></div>
        <div class="res-verdict">@txt</div>
        <div class="res-comment">@Model.Comment</div>
        <span class="bg bg-lg @cc">Confidence: @Model.Confidence.ToString("P0")</span>
    </div>

    <div class="crd">
        <div class="crd-hd">📊 Probabilities</div>
        <div class="pb"><div class="pb-lb"><span>🏠 Home Win (1)</span><strong style="color:var(--g)">@Model.Probability1.ToString("P1")</strong></div><div class="pb-bar"><div class="pb-fill pb-g" style="width:@(Model.Probability1*100)%"></div></div></div>
        <div class="pb"><div class="pb-lb"><span>🤝 Draw (X)</span><strong style="color:var(--y)">@Model.ProbabilityX.ToString("P1")</strong></div><div class="pb-bar"><div class="pb-fill pb-y" style="width:@(Model.ProbabilityX*100)%"></div></div></div>
        <div class="pb" style="margin-bottom:0"><div class="pb-lb"><span>✈️ Away Win (2)</span><strong style="color:var(--b)">@Model.Probability2.ToString("P1")</strong></div><div class="pb-bar"><div class="pb-fill pb-b" style="width:@(Model.Probability2*100)%"></div></div></div>
    </div>

    <div style="text-align:right;grid-column:1/-1"><a href="/prediction" class="btn btn-b">← New Prediction</a></div>
</div>
