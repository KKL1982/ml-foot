@model FootballPrediction.Web.Models.BatchResultViewModel
@{
    ViewData["Title"] = "Batch Results";
    int c1 = Model.Predictions.Count(p => p.PredictedResult == "1");
    int cX = Model.Predictions.Count(p => p.PredictedResult == "X");
    int c2 = Model.Predictions.Count(p => p.PredictedResult == "2");
}

<div class="pg-title">Batch Prediction Results</div>

<div class="kpi-g">
    <div class="kpi b"><div class="kpi-hd">📁 Matches Processed</div><div class="kpi-val">@Model.TotalMatches</div><div class="kpi-sub">From uploaded CSV</div></div>
    <div class="kpi g"><div class="kpi-hd">✅ Predictions</div><div class="kpi-val">@Model.SuccessfulPredictions</div><div class="kpi-sub">Successfully predicted</div></div>
    <div class="kpi"><div class="kpi-hd">📊 Distribution</div><div class="kpi-val" style="font-size:18px"><span style="color:var(--g)">@c1</span> / <span style="color:var(--y)">@cX</span> / <span style="color:var(--b)">@c2</span></div><div class="kpi-sub">1 — X — 2</div></div>
    <div class="kpi"><div class="kpi-hd">📈 Avg Confidence</div><div class="kpi-val" style="font-size:18px">@(Model.Predictions.Any() ? Model.Predictions.Average(p => p.Confidence).ToString("P0") : "—")</div></div>
</div>

<div class="crd">
    <div class="crd-hd" style="justify-content:space-between"><span>Predictions Table</span><a href="/batch" class="btn btn-o btn-sm">New Upload</a></div>
    <div class="tbl-w">
        <table class="tbl">
            <thead><tr><th>Date</th><th>League</th><th>Home</th><th>Away</th><th>Pred</th><th>1</th><th>X</th><th>2</th><th>Conf</th><th>Comment</th></tr></thead>
            <tbody>
                @foreach (var p in Model.Predictions) {
                    string bdg = p.PredictedResult switch{"1"=>"bg1","X"=>"bgx","2"=>"bg2",_=>""};
                    string cf = p.Confidence>=0.6?"cf-hi":p.Confidence>=0.45?"cf-md":"cf-lo";
                    <tr>
                        <td>@p.Date.ToString("yyyy-MM-dd")</td><td>@p.League</td><td>@p.HomeTeam</td><td>@p.AwayTeam</td>
                        <td><span class="bg @bdg">@p.PredictedResult</span></td>
                        <td>@p.Probability1.ToString("P0")</td><td>@p.ProbabilityX.ToString("P0")</td><td>@p.Probability2.ToString("P0")</td>
                        <td><span class="bg @cf">@p.Confidence.ToString("P0")</span></td>
                        <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@p.Comment">@p.Comment</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
